# Hybrid RAG Enterprise - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: OpenAI Configuration
# =============================================================================
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# OPTIONAL: OpenAI Model Configuration
# =============================================================================
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# OPTIONAL: LangSmith Observability (Recommended for Production)
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langchain-api-key-here
LANGCHAIN_PROJECT=hybrid-rag-enterprise

# =============================================================================
# OPTIONAL: RAPTOR Configuration
# =============================================================================
RAPTOR_MAX_LEVELS=3
RAPTOR_CLUSTER_SIZE=10
RAPTOR_SUMMARY_MODEL=gpt-4o-mini

# =============================================================================
# OPTIONAL: GraphRAG Configuration
# =============================================================================
GRAPHRAG_ENTITY_EXTRACTION_MODEL=gpt-4o-mini
GRAPHRAG_COMMUNITY_DETECTION=true

# =============================================================================
# OPTIONAL: Document Processing Configuration
# =============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =============================================================================
# OPTIONAL: ChromaDB Configuration
# =============================================================================
CHROMA_COLLECTION_NAME=hybrid_rag_docs

# =============================================================================
# OPTIONAL: CORS Configuration (for development)
# =============================================================================
CORS_ORIGINS=*

# =============================================================================
# OPTIONAL: Frontend API URL (for docker-compose)
# =============================================================================
VITE_API_URL=http://localhost:8000
