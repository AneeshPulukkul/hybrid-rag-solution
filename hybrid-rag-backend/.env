# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Langfuse Configuration (optional)
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Database Configuration
DATABASE_URL=sqlite:///./data/hybrid_rag.db

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma

# Graph Persist Directory
GRAPH_PERSIST_DIRECTORY=./data/graph

# RAPTOR Configuration
RAPTOR_PERSIST_DIRECTORY=./data/raptor
RAPTOR_MAX_LEVELS=3
RAPTOR_CLUSTER_THRESHOLD=0.5
RAPTOR_SUMMARY_MAX_TOKENS=500

# GraphRAG Configuration
GRAPHRAG_ENTITY_TYPES_STR=PERSON,ORGANIZATION,LOCATION,EVENT,CONCEPT,TECHNOLOGY,PRODUCT
GRAPHRAG_MAX_TRIPLETS_PER_CHUNK=10

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# CORS Configuration
CORS_ORIGINS_STR=*
